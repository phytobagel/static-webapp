{
  "routes": [
    {
      "route": "/*",
      "headers": {
        "X-Content-Type-Options": "nosniff",
        "X-Frame-Options": "DENY",
        "Referrer-Policy": "strict-origin-when-cross-origin"
      }
    }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/css/*", "/js/*", "/*.{png,jpg,jpeg,gif,svg,ico,webp,woff,woff2}"]
  },
  "mimeTypes": {
    ".json": "application/json"
  }
}
